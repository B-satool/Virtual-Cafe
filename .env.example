# Virtual Café Environment Configuration
# Copy this file to .env and update values as needed

# Server Configuration
PORT=3000
NODE_ENV=development

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=*
SOCKET_CORS_METHODS=GET,POST

# Timer Configuration (in seconds)
POMODORO_STUDY_TIME=1500     # 25 minutes
POMODORO_BREAK_TIME=300      # 5 minutes

# Room Configuration
DEFAULT_ROOM_CAPACITY=10
MIN_ROOM_CAPACITY=1
MAX_ROOM_CAPACITY=50

# Database Configuration (for future use)
DATABASE_URL=mongodb://localhost:27017/virtual-cafe
# DATABASE_URL=postgresql://user:password@localhost:5432/virtual-cafe

# Redis Configuration (for scaling, future use)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Session Configuration
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds
ROOM_CLEANUP_INTERVAL=300000  # Clean up empty rooms every 5 minutes

# Sound Files (for future audio implementation)
SOUND_RAIN_URL=/assets/sounds/rain.mp3
SOUND_CAFE_URL=/assets/sounds/cafe.mp3
SOUND_FIREPLACE_URL=/assets/sounds/fireplace.mp3
